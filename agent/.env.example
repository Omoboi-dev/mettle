# Copy to .env and fill in. The .env file is gitignored — never commit real keys.

# Claude API key for the agent's reasoning.
ANTHROPIC_API_KEY=sk-ant-...

# The AIRunner operator wallet's private key. This is a DEDICATED low-risk key:
# it only controls AIRunner, which is non-custodial (it can trade inside vaults but
# can never withdraw funds), so a leak can't move anyone's money. Do NOT use the
# deployer key here.
OPERATOR_PRIVATE_KEY=0x...
