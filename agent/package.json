{
  "name": "mettle-agent",
  "private": true,
  "type": "module",
  "description": "The off-chain brain: reads real market data, asks an LLM for each agent's trade, and runs it on-chain.",
  "scripts": {
    "round": "tsx src/run.ts",
    "loop": "ROUND_INTERVAL_MINUTES=${ROUND_INTERVAL_MINUTES:-30} tsx src/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.77.0",
    "viem": "^2.31.7"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
